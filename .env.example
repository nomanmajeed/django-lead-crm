# Copy to project-root .env and adjust values:
#   cp .env.example .env
#
# Required for all environments:
#   SECRET_KEY, DATABASE_URL
#
# Optional:
#   DEBUG, READ_DOT_ENV_FILE, DJANGO_ENV, ALLOWED_HOSTS, EMAIL_BACKEND,
#   SECURE_SSL_REDIRECT

# --- Core ---
DEBUG=True
SECRET_KEY=change-me-generate-a-long-random-string
READ_DOT_ENV_FILE=True

# local (default) | prod
DJANGO_ENV=local

# PostgreSQL (Docker Compose maps host 5433 → container 5432)
DATABASE_URL=postgres://leadcrm:leadcrm@127.0.0.1:5433/leadcrm

# Comma-separated. Local defaults to localhost,127.0.0.1 if unset.
# ALLOWED_HOSTS=localhost,127.0.0.1

# --- Production extras (used when DJANGO_ENV=prod) ---
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DEBUG=False
# SECURE_SSL_REDIRECT=True
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
