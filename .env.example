# Copy to project-root .env and adjust values:
#   cp .env.example .env
#
# Required for all environments:
#   SECRET_KEY, DATABASE_URL
#
# Optional:
#   DEBUG, READ_DOT_ENV_FILE, DJANGO_ENV, ALLOWED_HOSTS, EMAIL_BACKEND,
#   EMAIL_PROVIDER, DEFAULT_FROM_EMAIL, CELERY_BROKER_URL, EMAIL_WEBHOOK_SECRET,
#   SECURE_SSL_REDIRECT
#   SENTRY_DSN, SENTRY_ENVIRONMENT, LOG_LEVEL, DJANGO_ADMIN_ENABLED

# --- Core ---
DEBUG=True
SECRET_KEY=change-me-generate-a-long-random-string
READ_DOT_ENV_FILE=True

# local (default) | prod
DJANGO_ENV=local

# PostgreSQL (Docker Compose maps host 5433 → container 5432)
DATABASE_URL=postgres://leadcrm:leadcrm@127.0.0.1:5433/leadcrm

# Comma-separated. Local defaults to localhost,127.0.0.1 if unset.
# ALLOWED_HOSTS=localhost,127.0.0.1

# --- Production extras (used when DJANGO_ENV=prod) ---
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DEBUG=False
# SECURE_SSL_REDIRECT=True
# DJANGO_ADMIN_ENABLED=False
# SENTRY_DSN=https://key@o0.ingest.sentry.io/project
# SENTRY_ENVIRONMENT=production
# LOG_LEVEL=INFO


# --- Email engine / Celery ---
# EMAIL_PROVIDER=console
# DEFAULT_FROM_EMAIL=noreply@leadcrm.local
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_TASK_ALWAYS_EAGER=True
# EMAIL_WEBHOOK_SECRET=
# SENDGRID_API_KEY=
# POSTMARK_SERVER_TOKEN=
